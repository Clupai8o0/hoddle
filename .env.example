# Copy this file to .env.local and fill in values for your environment.
#
# LOCAL DEV (no rate limits, no real email):
#   1. Run: supabase start
#   2. Copy .env.local.local → .env.local
#   3. Paste the anon key + service_role key from the `supabase start` output
#   4. View magic link emails at http://127.0.0.1:54324
#
# PRODUCTION:
#   Get values from Supabase Dashboard → Project Settings → API

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=your-access-token

# Site URL — used for auth email redirect links.
# Must match the deployed domain (no trailing slash).
# In Supabase dashboard → Auth → URL Configuration, add
#   https://your-domain.com/api/auth/callback
#   https://your-domain.com/api/auth/mentor-callback
# to the Redirect URLs list.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Resend (transactional email — not needed for local dev)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=hello@hoddle.com.au
