# Copy this file to .env.local and fill in values for your environment.
#
# LOCAL DEV (no rate limits, no real email):
#   1. Run: supabase start
#   2. Copy .env.local.local → .env.local
#   3. Paste the anon key + service_role key from the `supabase start` output
#   4. View magic link emails at http://127.0.0.1:54324
#
# PRODUCTION:
#   Get values from Supabase Dashboard → Project Settings → API

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=your-access-token

# Site URL — used for auth email redirect links.
# Must match the deployed domain (no trailing slash).
# In Supabase dashboard → Auth → URL Configuration, add
#   https://your-domain.com/api/auth/callback
#   https://your-domain.com/api/auth/mentor-callback
# to the Redirect URLs list.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# App URL — used in email CTAs and OG metadata.
# Set to your current deployment URL (no trailing slash).
# Current production: https://hoddle-jet.vercel.app
# Future production: https://hoddle.com.au (update here and in Supabase Auth when live)
# See docs/url-configuration.md for every file that reads this value.
NEXT_PUBLIC_APP_URL=https://hoddle-jet.vercel.app

# Admin email — receives mentor application notifications.
# Required. Falls back to RESEND_FROM_EMAIL or GMAIL_USER if not set.
ADMIN_EMAIL=

# Gmail SMTP (transactional email — not needed for local dev)
# Use a Gmail App Password, not your account password.
# Create one at: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Airtable — UX feedback widget
# Create a Personal Access Token at https://airtable.com/create/tokens
# with scope: data.records:write
# Base ID is in the Airtable URL: https://airtable.com/{BASE_ID}/...
# Table ID (or table name) is in the URL when you open the table.
AIRTABLE_API_KEY=your-airtable-personal-access-token
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_FEEDBACK_TABLE_ID=tblXXXXXXXXXXXXXX
